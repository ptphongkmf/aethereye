{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "AetherEye",
  "version": "0.0.0",
  "identifier": "com.luxcadia.aethereye",

  "build": {
    "beforeDevCommand": "deno task dev:ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build:ui",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "AetherEye",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",

    "publisher": "PTPhongKMF",
    "copyright": "Copyright © 2025 PTPhongKMF",
    "homepage": "https://github.com/ptphongkmf/aethereye",

    "license": "AGPL-3.0-or-later",
    "licenseFile": "../LICENSE",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
